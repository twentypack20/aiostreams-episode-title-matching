{
  "id": "aiostreams-plugin",
  "name": "AIOStreams",
  "version": "0.8.3",
  "manifestURI": "",
  "language": "typescript",
  "type": "plugin",
  "description": "Stream content from AIOStreams directly in Seanime. Supports all streams with URLs.",
  "author": "Viren070",
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/aiostreams-light.png",
  "lang": "multi",
  "payloadURI": "",
  "isDevelopment": true,
  "website": "https://docs.aiostreams.viren070.me",
  "readme": "https://docs.aiostreams.viren070.me/guides/seanime",
  "notes": "You need an existing AIOStreams instance and configuration to use this plugin.",
  "userConfig": {
    "version": 1,
    "requiresConfig": true,
    "fields": [
      {
        "type": "text",
        "name": "manifestUrl",
        "label": "Manifest URL",
        "default": ""
      },
      {
        "type": "select",
        "name": "searchId",
        "label": "Preferred Media ID",
        "default": "imdbId",
        "options": [
          {
            "value": "imdbId",
            "label": "IMDb ID"
          },
          {
            "value": "kitsuId",
            "label": "Kitsu ID"
          }
        ]
      },
      {
        "type": "select",
        "name": "playerMode",
        "label": "Preferred player",
        "default": "builtin",
        "options": [
          {
            "value": "builtin",
            "label": "Built-in player"
          },
          {
            "value": "desktop",
            "label": "Desktop media player"
          },
          {
            "value": "external",
            "label": "External player link"
          }
        ]
      },
      {
        "type": "text",
        "name": "downloadLocation",
        "label": "Download location",
        "default": "$DOWNLOAD",
        "description": "Where to save downloaded files. Supported variables: $DOWNLOAD, $DESKTOP, $DOCUMENT, $HOME. You can also append a subdirectory, e.g. $DOWNLOAD/AIOStreams"
      },
      {
        "type": "text",
        "name": "cacheTtl",
        "label": "Cache TTL (minutes, 0 to disable)",
        "default": "30"
      },
      {
        "type": "switch",
        "name": "autoPlayFirstStream",
        "label": "Auto-play first stream",
        "default": "false"
      },
      {
        "type": "switch",
        "name": "showAnimeTab",
        "label": "Show \"AIOStreams\" tab on anime details page",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "showAnimePageButton",
        "label": "Show \"AIOStreams\" button on anime details page",
        "default": "false"
      },
      {
        "type": "switch",
        "name": "showEpisodeContextMenu",
        "label": "Add \"Stream with AIOStreams\" to episode card right-click menu",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "showEpisodeGridMenu",
        "label": "Add \"Stream with AIOStreams\" to episode grid (3-dot) menu",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "autoOpenResults",
        "label": "Auto-open results on any episode card click",
        "default": "false"
      }
    ]
  },
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": [
        "storage",
        "playback",
        "system",
        "anilist"
      ],
      "allow": {
        "networkAccess": {
          "allowedDomains": [
            "*"
          ],
          "reasoning": "This is mandatory as we need to be able to fetch from any AIOStreams instance you configure."
        },
        "readPaths": [
          "**/*"
        ],
        "writePaths": [
          "**/*"
        ]
      }
    }
  }
}